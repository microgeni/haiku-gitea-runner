# Build directories
build/
build_*/

# CMake artefacts
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt
Makefile

# Compiled binaries
act_runner
test_*

# Generated protobuf stubs (regenerate with protoc)
proto/*.pb.cc
proto/*.pb.h
proto/*.grpc.pb.cc
proto/*.grpc.pb.h

# Runner state / config (written at runtime)
.runner
config.yaml
*.runner

# Smoke-test credentials (never commit)
scripts/.gitea-env.json

# Editor / OS artefacts
*.swp
*.swo
*~
.DS_Store
.#*

# Haiku packagefs leftovers
*.hpkg
*.hvif

# Temporary files written by tests
/tmp/act_runner_*
