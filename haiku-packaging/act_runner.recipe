portVersion="0.2.0"
SUMMARY="A native Gitea Actions runner for Haiku OS"
DESCRIPTION="haiku-act-runner is a C++20 reimplementation of the Gitea act_runner \
for Haiku OS. It connects to a Gitea server via the Connect-RPC protocol \
(HTTP/1.1 + hand-coded Protocol Buffers — no gRPC dependency), polls for \
Actions workflow jobs, and executes them natively on the host (no Docker \
required).

Features:
- Full \${{ }} expression language with hashFiles() (SHA-256 via OpenSSL)
- Composite, JavaScript, and nested action support (uses:, recursion-guarded)
- Matrix expansion, job-level if: conditions, needs: dependencies
- Job-level timeout-minutes enforcement
- GITHUB_TOKEN, GITHUB_JOB, GITHUB_REF_TYPE, RUNNER_ENVIRONMENT env vars
- GITHUB_OUTPUT / GITHUB_ENV / GITHUB_PATH / GITHUB_STATE file protocols
- Local HTTP cache server (actions/cache@v4 compatible)
- Local HTTP artifact server (actions/upload-artifact@v4 / download-artifact@v4,
  Twirp JSON protocol)
- act_runner run: local multi-job workflow execution (no server needed)
- act_runner unregister: clean local state removal
- Haiku launch_daemon integration for automatic startup"

HOMEPAGE="https://github.com/yourusername/haiku-act-runner"
COPYRIGHT="2024-2025 haiku-act-runner contributors"
LICENSE="MIT"
REVISION="1"
# Local build: SOURCE_URI points at the tarball in the port's download/ directory.
# For a real release, replace with the GitHub archive URL and update CHECKSUM_SHA256.
SOURCE_URI="file:///Data/Code/Repos/haikuports/net-misc/haiku_act_runner/download/v$portVersion.tar.gz"
CHECKSUM_SHA256="244f2f749ac315d27edee901a069bd6f6a72eaf4d6ab5cc24b2780c351ebe1e7"
SOURCE_DIR="haiku-act-runner-$portVersion"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

portVersionCompat="$portVersion compat >= ${portVersion%%.*}"

PROVIDES="
	haiku_act_runner$secondaryArchSuffix = $portVersion
	cmd:act_runner$secondaryArchSuffix = $portVersion
	"

# Runtime: libs we NEEDED at link time (from objdump -p act_runner)
#   libmicrohttpd.so.12  → libmicrohttpd
#   libcurl.so.4         → curl
#   libyaml-cpp.so.0.8   → yaml_cpp0.8
#   libprotobuf.so.31    → protobuf
#   libcrypto.so.3       → openssl3
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libcurl$secondaryArchSuffix
	lib:libyaml_cpp$secondaryArchSuffix
	lib:libprotobuf$secondaryArchSuffix
	lib:libmicrohttpd$secondaryArchSuffix
	lib:libcrypto$secondaryArchSuffix
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libcurl$secondaryArchSuffix
	devel:libyaml_cpp$secondaryArchSuffix
	devel:libprotobuf$secondaryArchSuffix
	devel:libmicrohttpd$secondaryArchSuffix
	devel:libcrypto$secondaryArchSuffix
	nlohmann_json
	"

BUILD_PREREQUIRES="
	cmd:cmake
	cmd:make
	cmd:g++$secondaryArchSuffix
	"

defineDebugInfoPackage haiku_act_runner$secondaryArchSuffix \
	"$binDir"/act_runner

BUILD()
{
	# nlohmann/json is bundled in vendor/ — no network access needed.
	# All other deps are resolved via BUILD_REQUIRES above.

	cmake -B build \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX="$prefix" \
		-DCMAKE_INSTALL_DOCDIR="$docDir" \
		-DCMAKE_CXX_STANDARD=20 \
		-DCMAKE_CXX_EXTENSIONS=OFF \
		-DRUNNER_VERSION="$portVersion"

	# Build only the main executable (not test targets)
	cmake --build build --target act_runner -j"$jobs"
}

INSTALL()
{
	# Install using cmake --install to avoid triggering test builds
	cmake --install build

	# Install the launch_daemon user-service descriptor.
	# Haiku's launch_daemon picks this up from $dataDir/user_launch/ and
	# starts act_runner at login when 'launch_roster start act_runner' is run.
	mkdir -p "$dataDir/user_launch"
	sed \
		-e "s|@BIN@|$binDir/act_runner|" \
		haiku-packaging/launch_daemon/act_runner \
		> "$dataDir/user_launch/act_runner"
}

TEST()
{
	# Build and run all 12 test suites (226 tests).
	# No network required — CacheServer and artifact server tests bind
	# to ephemeral localhost ports.
	# The test_process_spawner and test_workflow_orchestrator suites use
	# flaky()/retry_on_flake() wrappers for the known Haiku posix_spawn
	# SIGKILLTHR race; they are reliable over multiple runs.
	cmake --build build -j"$jobs"
	ctest --test-dir build --output-on-failure -j4
}
