portVersion="0.2.0"
SUMMARY="A native Gitea Actions runner for Haiku OS"
DESCRIPTION="haiku-act-runner is a C++20 reimplementation of the Gitea act_runner \
for Haiku OS. It connects to a Gitea server via the Connect-RPC protocol \
(HTTP/1.1 + hand-coded Protocol Buffers — no gRPC dependency), polls for \
Actions workflow jobs, and executes them natively on the host (no Docker \
required).

Features:
- Full \${{ }} expression language
- actions/checkout support (git clone with token auth)
- Composite and JavaScript action support (uses:, recursion-guarded)
- Matrix expansion, job-level if: conditions, needs: dependencies
- Job-level timeout-minutes enforcement
- Self-restart watchdog (monitors child daemon, restarts on crash)
- Local HTTP cache server (actions/cache compatible Twirp API)
- Local HTTP artifact server (actions/upload-artifact / download-artifact)
- act_runner run: local multi-job workflow execution (no server needed)
- Haiku launch_daemon integration for automatic startup at login"

HOMEPAGE="https://github.com/haiku/haiku-act-runner"
COPYRIGHT="2024-2025 haiku-act-runner contributors"
LICENSE="MIT"
REVISION="1"

# To build a release tarball:
#   git archive --prefix=haiku-act-runner-$portVersion/ HEAD \
#       | gzip > haiku-act-runner-$portVersion.tar.gz
# Then place it in the port's download/ directory and update CHECKSUM_SHA256.
SOURCE_URI="https://github.com/haiku/haiku-act-runner/archive/refs/tags/v$portVersion.tar.gz"
CHECKSUM_SHA256="REPLACE_WITH_ACTUAL_SHA256_OF_RELEASE_TARBALL"
SOURCE_DIR="haiku-act-runner-$portVersion"

ARCHITECTURES="all !x86_gcc2"
SECONDARY_ARCHITECTURES="x86"

portVersionCompat="$portVersion compat >= ${portVersion%%.*}"

PROVIDES="
	haiku_act_runner$secondaryArchSuffix = $portVersion
	cmd:act_runner$secondaryArchSuffix = $portVersion
	"

# Runtime dependencies (from: objdump -p act_runner | grep NEEDED)
#   libcurl.so.4        → curl
#   libyaml-cpp.so.0.8  → yaml_cpp0.8
#   libprotobuf.so.31   → protobuf
#   libmicrohttpd.so.12 → libmicrohttpd
#   libcrypto.so.3      → openssl3
#   libbe.so            → haiku (always present)
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libcurl$secondaryArchSuffix
	lib:libyaml_cpp$secondaryArchSuffix
	lib:libprotobuf$secondaryArchSuffix
	lib:libmicrohttpd$secondaryArchSuffix
	lib:libcrypto$secondaryArchSuffix
	cmd:git
	"

BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libcurl$secondaryArchSuffix
	devel:libyaml_cpp$secondaryArchSuffix
	devel:libprotobuf$secondaryArchSuffix
	devel:libmicrohttpd$secondaryArchSuffix
	devel:libcrypto$secondaryArchSuffix
	nlohmann_json
	"

BUILD_PREREQUIRES="
	cmd:cmake
	cmd:make
	cmd:g++$secondaryArchSuffix
	cmd:git
	"

defineDebugInfoPackage haiku_act_runner$secondaryArchSuffix \
	"$binDir"/act_runner

BUILD()
{
	# nlohmann/json is bundled in vendor/ — no network access needed.
	# All other deps are resolved via BUILD_REQUIRES above.
	#
	# Use -O1 (not -O2/-O3): higher optimisation levels expose a Haiku-specific
	# UB in GCC 13 that causes silent daemon crashes after task completion.
	# -O1 + debug info gives a good balance of performance and stability.

	cmake -B build \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_CXX_FLAGS_RELWITHDEBINFO="-O1 -g -DNDEBUG" \
		-DCMAKE_INSTALL_PREFIX="$prefix" \
		-DCMAKE_INSTALL_DOCDIR="$docDir" \
		-DCMAKE_CXX_STANDARD=20 \
		-DCMAKE_CXX_EXTENSIONS=OFF \
		-DRUNNER_VERSION="$portVersion"

	cmake --build build --target act_runner -j"$jobs"
}

INSTALL()
{
	cmake --install build

	# Install the launch_daemon user-service descriptor.
	# Haiku's launch_daemon scans $dataDir/launch/ (= ~/config/data/launch/)
	# at login and starts registered services when their conditions are met.
	# The 'require: file config.yaml' guard prevents crash-looping when the
	# runner hasn't been registered yet.
	mkdir -p "$dataDir/launch"
	sed "s|@BIN@|$binDir/act_runner|" \
		haiku-packaging/launch_daemon/act_runner.launch.template \
		> "$dataDir/launch/act_runner.launch"

	# Ship the install helper and example config in the docs directory.
	mkdir -p "$docDir"
	cp haiku-packaging/launch_daemon/install-service.sh "$docDir/"
	cp config.yaml.example "$docDir/"
}

TEST()
{
	# Build and run all 14 test suites (318 individual test cases).
	# No network required — all tests run against mock or localhost servers.
	cmake --build build -j"$jobs"
	ctest --test-dir build --output-on-failure -j1
}
