# act_runner — Gitea Actions runner service for Haiku
#
# This file is a Haiku launch_daemon(8) service descriptor.
#
# Installation:
#   1. Register the runner first:
#        act_runner register --url https://your.gitea.example \
#                            --token <registration_token>     \
#                            --labels haiku:host
#
#   2. Copy binary and service file:
#        cp build/act_runner /boot/home/config/non-packaged/bin/
#        cp haiku-packaging/launch_daemon/act_runner.launch \
#               /boot/home/config/non-packaged/data/launch/
#
#      Or use the helper script:
#        bash haiku-packaging/launch_daemon/install-service.sh
#
#   3. Start the service:
#        launch_roster start x-vnd.act-runner
#
# To view logs:
#   syslog  (or look at the Haiku syslog server output)
#
# To stop permanently:
#   launch_roster stop x-vnd.act-runner
#
# To disable at boot:
#   launch_roster disable x-vnd.act-runner
#
# launch_daemon restarts the service automatically if it exits unexpectedly.

service x-vnd.act-runner {
    launch /boot/home/config/non-packaged/bin/act_runner daemon

    # Working directory (where relative paths in config are resolved)
    working_directory /boot/home/config/settings/act_runner

    # Environment variables
    env {
        HOME /boot/home
    }

    # Only start once the network stack is ready
    on {
        network_available
    }

    # Require that the runner has been registered (config.yaml must exist).
    # This prevents the service from crash-looping when the runner is not
    # set up yet.
    require {
        file /boot/home/config/settings/act_runner/config.yaml
    }

    # Don't launch in safe-mode boots.
    no_safemode
}
